//configuration
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//A user in CoachSync is either a COACH or an ATHLETE
enum Role {
  COACH
  ATHLETE
}

model User {
  id           String   @id @default(cuid()) /// uniqueID, auto-generated
  email        String   @unique              /// Must be unique across all users
  passwordHash String                        /// Stored password (harshed, never plain text)
  name         String                        
  role         Role                          /// Either COACH or ATHLETE
  language     String   @default("en")       /// Preferred language (ISO 639-1 code). For coaches, this is the DeepL target language when auto-translating athlete feedback notes.
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations 
  coachRelations   CoachAthleteRelation[] @relation("Coach")
  athleteRelations CoachAthleteRelation[] @relation("Athlete")
  coachPrograms    TrainingProgram[]      @relation("CoachPrograms")
  athletePrograms  TrainingProgram[]      @relation("AthletePrograms")
  coachInvites     InviteLink[]           @relation("CoachInvites")
  usedInvites      InviteLink[]           @relation("UsedInvites")
  athleteSessions  Session[]              @relation("AthleteSessions")
  coachSessions    Session[]              @relation("CoachSessions")
  coachEvents      Event[]                @relation("CoachEvents")
  athleteEvents    Event[]                @relation("AthleteEvents")
  athleteRecords   PersonalRecord[]       @relation("AthleteRecords")
  loggedRecords    PersonalRecord[]       @relation("LoggedRecords")
  coachComments    CoachComment[]         @relation("CoachComments")
  pushSubscriptions PushSubscription[]
}

// many to many relationship (one coach can have many athletes, and one athlete can have many coaches)
model CoachAthleteRelation {
  id        String   @id @default(cuid())
  coachId   String                          /// Foreigh key -> points to a User who is a COACH
  athleteId String                          /// Foreigh key -> points to a User who is an ATHLETE
  createdAt DateTime @default(now())

  // if the coach or athlete is deleted, this relation row is also automatically deleted
  coach   User @relation("Coach", fields: [coachId], references: [id], onDelete: Cascade)
  athlete User @relation("Athlete", fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([coachId, athleteId])            /// A coach-athlete pair can only exist once (no duplicate relationships)
}

model TrainingProgram {
  id          String    @id @default(cuid())
  title       String
  description String?                         /// this field is optional (nullable)
  coachId     String                          /// who created this program
  athleteId   String?                         /// which athlete assigned to this program (optional)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  coach    User              @relation("CoachPrograms", fields: [coachId], references: [id], onDelete: Cascade)
  athlete  User?             @relation("AthletePrograms", fields: [athleteId], references: [id], onDelete: SetNull)
  sessions TrainingSession[]                  
}

model InviteLink {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  coachId   String
  expiresAt DateTime                        /// TTL set by the service layer (default 24 hours from creation). Expired tokens are rejected at accept time.
  usedById  String?
  createdAt DateTime  @default(now())

  coach   User  @relation("CoachInvites", fields: [coachId], references: [id], onDelete: Cascade)
  usedBy  User? @relation("UsedInvites", fields: [usedById], references: [id], onDelete: SetNull)
}


// one-to-many relationship(one TrainingProgram has many TrainingSessions)
// the relationshipt would be gone if it is too complicated to my actual coach
model TrainingSession {
  id          String   @id @default(cuid())
  programId   String                         /// which program this session belongs
  title       String
  description String?                        /// this field is optional (nullable)
  scheduledAt DateTime                       
  durationMin Int?                           /// this field is optional (nullable)
  notes       String?                        /// this field is optional (nullable)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
}

// ── Push Subscriptions ────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Coach Comments ────────────────────────────────────────────────────────────

model CoachComment {
  id        String   @id @default(cuid())
  sessionId String
  coachId   String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  coach   User    @relation("CoachComments", fields: [coachId], references: [id], onDelete: Cascade)
}

// ── Personal Records ──────────────────────────────────────────────────────────

enum Surface {
  OUTDOOR
  INDOOR
}

model PersonalRecord {
  id          String   @id @default(cuid())
  athleteId   String
  discipline  String
  performance Float
  unit        String
  wind        Float?                         /// this field is optional (nullable), it matters for events wind-assistabled (short sprints, or long jump)
  date        DateTime
  competition String?                        /// this field is optional (nullable)
  location    String?                        /// this field is optional (nullable)
  surface     Surface  @default(OUTDOOR)
  loggedById  String
  createdAt   DateTime @default(now())

  athlete  User @relation("AthleteRecords", fields: [athleteId], references: [id], onDelete: Cascade)
  loggedBy User @relation("LoggedRecords", fields: [loggedById], references: [id], onDelete: Cascade)
}

// ── Events ────────────────────────────────────────────────────────────────────

enum EventType {
  MATCH
  CAMP
  TEST
  OTHER
}

/// ***consider to change the type, allow users to enter any test***
enum TestType {
  VO2MAX
  LACTIC_TOLERANCE
  TIME_TRIAL
  FIELD_TEST
}

// Both coachId and athleteId are non-nullable. When an athlete creates their own event,
// both are set to the athlete's userId — this allows a single ownership rule across roles.
model Event {
  id        String    @id @default(cuid())
  title     String
  type      EventType
  testType  TestType?
  date      DateTime
  location  String?                          /// this field is optional (nullable)
  notes     String?                          /// this field is optional (nullable)
  coachId   String
  athleteId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  coach   User @relation("CoachEvents", fields: [coachId], references: [id], onDelete: Cascade)
  athlete User @relation("AthleteEvents", fields: [athleteId], references: [id], onDelete: Cascade)
}

// ── Athlete Session Entry ──────────────────────────────────────────────────
/// ***consider to change the type, allow users to enter any type of training***
enum SessionTypeValue {
  SPEED
  ENDURANCE
  VOLUME
  TECHNIQUE
  HILLS
  HURDLES
  GYM
  RECOVERY
}

enum IncidentType {
  NONE
  CRAMP
  PAIN
  EARLY_FATIGUE
}

model Session {
  id          String    @id @default(cuid())
  date        DateTime
  title       String
  durationMin Int?
  athleteId   String
  coachId     String?                       /// Nullable — athletes can log sessions independently before a coach relationship is established.
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  athlete     User             @relation("AthleteSessions", fields: [athleteId], references: [id], onDelete: Cascade)
  coach       User?            @relation("CoachSessions", fields: [coachId], references: [id], onDelete: SetNull)
  types       SessionType[]
  warmupItems WarmupItem[]
  sets        TrainingSet[]
  drills      Drill[]
  feedback    SessionFeedback?
  comments    CoachComment[]
}

model SessionType {
  id        String           @id @default(cuid())
  type      SessionTypeValue
  sessionId String

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model WarmupItem {
  id        String  @id @default(cuid())
  order     Int
  name      String
  detail    String?                       /// this field is optional (nullable)
  sessionId String

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model TrainingSet {
  id        String  @id @default(cuid())
  order     Int
  abandoned Boolean @default(false)
  note      String?                      /// this field is optional (nullable)
  sessionId String

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  laps    Lap[]
}

model Lap {
  id          String  @id @default(cuid())
  order       Int
  distance    String
  timeSeconds Float?                      /// Elapsed time for this lap in seconds (e.g. 13.2 for a 100m sprint). Null if the athlete didn't record a time.
  note        String?                     /// this field is optional (nullable)
  setId       String

  set TrainingSet @relation(fields: [setId], references: [id], onDelete: Cascade)
}

model Drill {
  id        String @id @default(cuid())
  order     Int
  name      String
  sessionId String

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SessionFeedback {
  id             String  @id @default(cuid())
  fatigue        Int                             /// Athlete self-rating: 1 (minimal fatigue) – 5 (complete exhaustion). Inclusive bounds.
  rpe            Int                             /// Rate of Perceived Exertion (Borg CR10 scale): 1 (very light) – 10 (maximal effort). Inclusive bounds.
  note           String?                       /// this field is optional (nullable)
  noteTranslated String?                       /// translated version of note (coach's language)
  noteSourceLang String?                       /// detected source language from DeepL (e.g. "JA")
  noteTargetLang String?                       /// coach's language code used as translation target (e.g. "EN")
  sessionId      String  @unique

  session   Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  incidents Incident[]
}

model Incident {
  id         String       @id @default(cuid())
  type       IncidentType
  bodyPart   String?                       /// this field is optional (nullable)
  severity   Int?                          /// Subjective severity of the incident: 1 (minor discomfort) – 5 (session-ending). Null if not recorded.
  detail     String?                       /// this field is optional (nullable)                
  feedbackId String

  feedback SessionFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}
